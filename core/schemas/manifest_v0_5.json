{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://narrative-orchestrator.salesforce.com/schemas/manifest/v0.5",
  "title": "Enhanced Narrative Orchestrator Manifest Schema v0.5",
  "description": "Enhanced manifest schema with SLDS integration, design system support, and comprehensive validation",
  "type": "object",
  "required": ["schema_version", "initiative_metadata", "data_tier", "flows", "drive", "figma"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.5",
      "description": "Manifest schema version"
    },
    "initiative_metadata": {
      "type": "object",
      "required": ["name", "version", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Initiative display name"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
          "description": "Semantic version (e.g., 1.0, 2.1.3)"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of manifest creation"
        },
        "brand_context": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary_brand": {
              "type": "string",
              "description": "Primary brand name (e.g., 'Wolverine Worldwide', 'Acme Corp')"
            },
            "sub_brands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Additional brand names or product lines"
            },
            "brand_guidelines_url": {
              "type": ["string", "null"],
              "format": "uri",
              "description": "Link to brand guidelines documentation"
            }
          }
        },
        "handoff_metadata": {
          "type": "object",
          "required": ["last_updated_by", "last_updated_at", "status"],
          "additionalProperties": false,
          "properties": {
            "last_updated_by": {
              "type": "string",
              "description": "Email or name of last person to update manifest"
            },
            "last_updated_at": {
              "type": "string",
              "format": "date-time",
              "description": "ISO-8601 timestamp of last update"
            },
            "status": {
              "type": "string",
              "enum": ["active", "paused", "archived", "review_needed"],
              "description": "Current project status"
            },
            "handoff_notes": {
              "type": "string",
              "maxLength": 1000,
              "description": "Notes for development or design team"
            },
            "design_review_status": {
              "type": "string",
              "enum": ["pending", "approved", "needs_revision"],
              "description": "Design review and approval status"
            }
          }
        }
      }
    },
    "data_tier": {
      "type": "string",
      "enum": ["1", "2", "3"],
      "description": "Data complexity tier (1=basic, 2=moderate, 3=complex)"
    },
    "design_system": {
      "type": "object",
      "required": ["framework", "theme"],
      "additionalProperties": false,
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["slds_v2", "custom", "none"],
          "description": "Design system framework to use"
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "auto"],
          "description": "Color theme preference"
        },
        "brand_tokens": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary_color": {
              "type": "string",
              "pattern": "^(#[0-9A-Fa-f]{6}|slds_[a-z_]+)$",
              "description": "Primary brand color (hex or SLDS token)"
            },
            "secondary_color": {
              "type": "string",
              "pattern": "^(#[0-9A-Fa-f]{6}|slds_[a-z_]+)$",
              "description": "Secondary brand color (hex or SLDS token)"
            },
            "accent_color": {
              "type": "string",
              "pattern": "^(#[0-9A-Fa-f]{6}|slds_[a-z_]+)$",
              "description": "Accent color for highlights (hex or SLDS token)"
            },
            "font_family": {
              "type": "string",
              "description": "Primary font family or SLDS token"
            }
          }
        },
        "accessibility": {
          "type": "object",
          "required": ["wcag_level"],
          "additionalProperties": false,
          "properties": {
            "wcag_level": {
              "type": "string",
              "enum": ["AA", "AAA"],
              "description": "WCAG compliance level target"
            },
            "color_contrast_verified": {
              "type": "boolean",
              "description": "Whether color contrast has been verified"
            },
            "screen_reader_optimized": {
              "type": "boolean",
              "description": "Whether designs include screen reader optimization"
            }
          }
        },
        "responsive_breakpoints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mobile": {
              "type": "string",
              "pattern": "^\\d+px$",
              "description": "Mobile breakpoint (default: 390px)"
            },
            "tablet": {
              "type": "string",
              "pattern": "^\\d+px$",
              "description": "Tablet breakpoint (default: 768px)"
            },
            "desktop": {
              "type": "string",
              "pattern": "^\\d+px$",
              "description": "Desktop breakpoint (default: 1200px)"
            }
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic", "channels", "steps"],
        "additionalProperties": false,
        "properties": {
          "topic": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Flow topic name (e.g., 'WISMO', 'Returns')"
          },
          "channels": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["web", "sms", "email", "voice"]
            },
            "description": "Supported channels for this flow"
          },
          "flow_metadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "primary_persona": {
                "type": "string",
                "description": "Target user persona for this flow"
              },
              "complexity_score": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5,
                "description": "Flow complexity rating (1-5)"
              },
              "estimated_completion_time": {
                "type": "string",
                "pattern": "^\\d+[ms]$",
                "description": "Estimated completion time (e.g., '5m', '30s')"
              }
            }
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["step_number", "step_name", "is_edge_case"],
              "additionalProperties": false,
              "properties": {
                "step_number": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Sequential step number"
                },
                "step_name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 50,
                  "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
                  "description": "Step identifier (alphanumeric and underscore only)"
                },
                "is_edge_case": {
                  "type": "boolean",
                  "description": "Whether this step handles an edge case"
                },
                "edge_case_priority": {
                  "type": ["integer", "null"],
                  "minimum": 1,
                  "description": "Priority order for edge cases (required if is_edge_case=true)"
                },
                "design_notes": {
                  "type": ["string", "null"],
                  "maxLength": 500,
                  "description": "Design-specific notes or requirements"
                },
                "accessibility_notes": {
                  "type": ["string", "null"],
                  "maxLength": 500,
                  "description": "Accessibility considerations for this step"
                },
                "utterances": {
                  "type": "object",
                  "required": ["agent", "user"],
                  "additionalProperties": false,
                  "properties": {
                    "agent": {
                      "type": "string",
                      "maxLength": 1000,
                      "description": "Default agent response"
                    },
                    "user": {
                      "type": "string",
                      "maxLength": 1000,
                      "description": "Expected user input"
                    }
                  }
                },
                "channels": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "web": {
                      "type": "object",
                      "required": ["agent", "user"],
                      "additionalProperties": false,
                      "properties": {
                        "agent": {
                          "type": "string",
                          "maxLength": 1000,
                          "description": "Web-specific agent message"
                        },
                        "user": {
                          "type": "string",
                          "maxLength": 1000,
                          "description": "Web-specific user input"
                        },
                        "template": {
                          "type": "string",
                          "enum": ["success_confirmation", "form_collection", "data_display", "status_messaging"],
                          "description": "Web template pattern to use"
                        },
                        "ui_components": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": ["button", "input", "dropdown", "card", "modal", "toast", "table", "chart"]
                          },
                          "description": "UI components needed for this step"
                        },
                        "slds_patterns": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "Specific SLDS patterns to implement"
                        }
                      }
                    },
                    "sms": {
                      "type": "object",
                      "required": ["agent", "user"],
                      "additionalProperties": false,
                      "properties": {
                        "agent": {
                          "type": "string",
                          "maxLength": 160,
                          "description": "SMS-optimized agent message (160 char limit)"
                        },
                        "user": {
                          "type": "string",
                          "maxLength": 160,
                          "description": "Expected SMS user response"
                        },
                        "template": {
                          "type": "string",
                          "enum": ["conversation_thread", "status_notification"],
                          "description": "SMS template pattern to use"
                        },
                        "interface_style": {
                          "type": "string",
                          "enum": ["native_mobile", "web_sms"],
                          "description": "SMS interface styling approach"
                        }
                      }
                    },
                    "email": {
                      "type": "object",
                      "required": ["subject", "body"],
                      "additionalProperties": false,
                      "properties": {
                        "subject": {
                          "type": "string",
                          "maxLength": 100,
                          "description": "Email subject line"
                        },
                        "body": {
                          "type": "string",
                          "maxLength": 5000,
                          "description": "Email body content"
                        },
                        "template": {
                          "type": "string",
                          "enum": ["transactional_thread", "support_response", "notification_alert"],
                          "description": "Email template pattern to use"
                        },
                        "template_type": {
                          "type": "string",
                          "enum": ["transactional", "marketing", "support"],
                          "description": "Email template category"
                        },
                        "thread_context": {
                          "type": "boolean",
                          "description": "Whether to display as email thread"
                        }
                      }
                    },
                    "voice": {
                      "type": "object",
                      "required": ["agent_speech", "expected_user_input"],
                      "additionalProperties": false,
                      "properties": {
                        "agent_speech": {
                          "type": "string",
                          "maxLength": 500,
                          "description": "Text-to-speech content for voice interaction"
                        },
                        "expected_user_input": {
                          "type": "string",
                          "maxLength": 200,
                          "description": "Expected spoken user response"
                        },
                        "fallback_prompts": {
                          "type": "array",
                          "maxItems": 3,
                          "items": {
                            "type": "string",
                            "maxLength": 200
                          },
                          "description": "Fallback prompts if user input not understood"
                        }
                      }
                    }
                  }
                },
                "proto_bot": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "sf_object": {
                      "type": "string",
                      "description": "Salesforce object to interact with (or 'not_provided')"
                    },
                    "action_type": {
                      "type": "string",
                      "enum": ["query", "create", "update", "delete", "not_provided"],
                      "description": "Type of Salesforce action"
                    },
                    "auth_context": {
                      "type": "string",
                      "description": "Authentication context required (or 'not_provided')"
                    },
                    "apex_methods": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Apex methods to invoke"
                    }
                  }
                }
              },
              "if": {
                "properties": {
                  "is_edge_case": {
                    "const": true
                  }
                }
              },
              "then": {
                "required": ["edge_case_priority"]
              }
            }
          }
        }
      }
    },
    "terminology_map": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "type": "string"
        }
      },
      "description": "Term replacement map for consistent terminology"
    },
    "drive": {
      "type": "object",
      "required": ["project_folder", "exports_folder"],
      "additionalProperties": false,
      "properties": {
        "project_folder": {
          "type": "string",
          "minLength": 1,
          "description": "Google Drive project folder path"
        },
        "exports_folder": {
          "type": "string",
          "minLength": 1,
          "description": "Folder path for exported assets"
        },
        "deck_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to generated stakeholder deck"
        },
        "auto_sync": {
          "type": "boolean",
          "description": "Enable automatic Drive synchronization"
        }
      }
    },
    "figma": {
      "type": "object",
      "required": ["target_file_url"],
      "additionalProperties": false,
      "properties": {
        "target_file_url": {
          "type": ["string", "null"],
          "pattern": "^https://www\\.figma\\.com/(design|board)/[A-Za-z0-9]+/.*$",
          "description": "Figma file URL for design output"
        },
        "design_system_library": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to linked design system library"
        },
        "brand_kit_library": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to brand kit/style guide library"
        }
      }
    },
    "google_slides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_generate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically generate presentation after Figma build"
        },
        "template_style": {
          "type": "string",
          "enum": ["three_tier", "linear", "custom"],
          "default": "three_tier",
          "description": "Presentation organization strategy"
        },
        "include_flow_diagrams": {
          "type": "boolean",
          "default": true,
          "description": "Generate automated flow diagrams from manifest steps"
        },
        "persona_examples": {
          "type": "boolean",
          "default": true,
          "description": "Include early persona comparison slides"
        },
        "export_formats": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pdf", "pptx", "png"]
          },
          "default": ["pdf"],
          "description": "Export formats for generated presentation"
        },
        "custom_branding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "logo_url": {
              "type": ["string", "null"],
              "format": "uri",
              "description": "URL to brand logo for slides"
            },
            "color_scheme": {
              "type": "object",
              "properties": {
                "primary": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
                "secondary": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
                "accent": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"}
              }
            }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_org": {
          "type": "string",
          "description": "Target Salesforce org for deployment (or 'not_provided')"
        },
        "release_date": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Planned release date (ISO-8601)"
        },
        "stakeholder_reviews": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of required stakeholder approvals"
        }
      }
    }
  }
}