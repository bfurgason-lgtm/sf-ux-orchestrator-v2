{
  "template": {
    "name": "SMS Status Notification",
    "version": "1.0",
    "description": "Concise status update messages optimized for SMS delivery with clear information hierarchy",
    "framework": "sms_optimized",
    "character_efficient": true,
    "layout": {
      "notification_structure": {
        "type": "structured_message",
        "max_length": 160,
        "format": "status_update",
        "elements": [
          {
            "type": "status_header",
            "content": "{status_emoji} {status_text}",
            "character_limit": 30,
            "format": "emoji + short_text",
            "examples": [
              "✅ Order Confirmed",
              "📦 Shipped Today", 
              "🚚 Out for Delivery",
              "✨ Delivered"
            ]
          },
          {
            "type": "key_details",
            "content": "{detail_line}",
            "character_limit": 80,
            "format": "concise_info",
            "patterns": [
              "Order #{order_id} - {product_name}",
              "Tracking: {tracking_number}",
              "Est. delivery: {delivery_date}"
            ]
          },
          {
            "type": "action_prompt",
            "content": "{cta_text}",
            "character_limit": 40,
            "format": "call_to_action",
            "examples": [
              "Track: link.co/track123",
              "Reply HELP for support",
              "Rate your experience"
            ]
          }
        ]
      }
    },
    "message_templates": {
      "order_confirmation": {
        "format": "✅ Order Confirmed\\n{order_details}\\nExpected: {delivery_date}\\nTrack: {tracking_link}",
        "character_count": "~140",
        "example": "✅ Order Confirmed\\nORD-2024-789456 - Your Item\\nExpected: March 25\\nTrack: yourco.co/t/abc123"
      },
      "shipping_notification": {
        "format": "📦 Shipped!\\n{product} via {carrier}\\nTracking: {tracking_number}\\nETA: {delivery_date}",
        "character_count": "~130",
        "example": "📦 Shipped!\\n{product_name} via UPS\\nTracking: 1Z999AA1234567890\\nETA: March 25"
      },
      "delivery_update": {
        "format": "🚚 Out for delivery\\n{product}\\nExpected by {time}\\nReply HELP if needed",
        "character_count": "~100",
        "example": "🚚 Out for delivery\\n{product_name}\\nExpected by 6 PM\\nReply HELP if needed"
      },
      "delivered_confirmation": {
        "format": "✨ Delivered!\\n{product} - {location}\\n{timestamp}\\nEnjoy! Rate: {rating_link}",
        "character_count": "~120", 
        "example": "✨ Delivered!\\n{product_name} - Front door\\n2:34 PM\\nEnjoy! Rate: yourco.co/r/abc"
      },
      "issue_resolution": {
        "format": "🔧 Issue Resolved\\n{resolution_summary}\\nRef: {case_number}\\nQuestions? Reply HELP",
        "character_count": "~130",
        "example": "🔧 Issue Resolved\\nReplacement shipped today\\nRef: CS-2024-1547\\nQuestions? Reply HELP"
      }
    },
    "optimization_rules": {
      "character_efficiency": {
        "abbreviations": {
          "delivery": "del",
          "tracking": "track", 
          "estimated": "est",
          "reference": "ref",
          "questions": "?s"
        },
        "link_shortening": "required",
        "emoji_usage": "status_clarity",
        "number_formatting": "compact"
      },
      "readability": {
        "line_breaks": "strategic_spacing",
        "key_info_first": true,
        "scannable_format": true,
        "action_clear": true
      },
      "engagement": {
        "emoji_positioning": "status_indicator",
        "call_to_action": "always_included",
        "personalization": "order_specific",
        "urgency_appropriate": true
      }
    },
    "response_patterns": {
      "help_keywords": ["HELP", "SUPPORT", "ISSUE", "PROBLEM"],
      "tracking_keywords": ["TRACK", "STATUS", "WHERE"], 
      "stop_keywords": ["STOP", "UNSUBSCRIBE", "END"],
      "auto_responses": {
        "HELP": "{brand_name} Support: Call {support_phone} or visit {support_url}/help. Reply STOP to end.",
        "TRACK": "Track your order: {support_url}/track or reply with order number for instant status.",
        "STOP": "You've unsubscribed from {brand_name} SMS. You can opt back in at {support_url}/sms"
      }
    },
    "delivery_timing": {
      "business_hours": {"start": "8:00", "end": "20:00", "timezone": "local"},
      "frequency_limits": {"max_per_day": 3, "min_interval_hours": 2},
      "urgency_overrides": ["delivery_exception", "security_alert"],
      "quiet_hours": {"start": "21:00", "end": "7:00"}
    },
    "compliance": {
      "opt_out_required": true,
      "sender_identification": true,
      "frequency_disclosure": true,
      "terms_reference": "{support_url}/sms-terms"
    },
    "analytics": {
      "delivery_tracking": true,
      "engagement_metrics": ["open_rate", "response_rate", "click_through"],
      "opt_out_tracking": true,
      "keyword_analysis": true
    }
  }
}