{
  "template": {
    "name": "SLDS Agentforce Success Confirmation",
    "version": "1.0",
    "description": "Clean success messaging with status banner and structured data display for Agentforce lookup confirmation flows",
    "framework": "slds_v2",
    "responsive": true,
    "accessibility": "WCAG_AA",
    "layout": {
      "container": {
        "type": "frame",
        "width": 1200,
        "height": 800,
        "background": "#FAFAFA",
        "padding": {"top": 50, "right": 200, "bottom": 50, "left": 200},
        "layout_mode": "vertical",
        "item_spacing": 24
      },
      "success_banner": {
        "type": "frame",
        "width": 800,
        "height": 64,
        "background": "#45C65A",
        "border_radius": 8,
        "padding": {"top": 16, "right": 20, "bottom": 16, "left": 20},
        "layout_mode": "horizontal",
        "item_spacing": 12,
        "alignment": "center",
        "elements": [
          {
            "type": "icon",
            "name": "checkmark",
            "color": "#FFFFFF",
            "size": 20
          },
          {
            "type": "text",
            "content": "{success_message}",
            "font_family": "Salesforce Sans",
            "font_weight": "Bold",
            "font_size": 16,
            "color": "#FFFFFF",
            "placeholder": "Order Found! Here are your order details:"
          }
        ]
      },
      "data_card": {
        "type": "frame", 
        "width": 800,
        "height": "auto",
        "background": "#FFFFFF",
        "border": {"color": "#D8DDE6", "width": 1},
        "border_radius": 8,
        "padding": {"top": 24, "right": 24, "bottom": 24, "left": 24},
        "layout_mode": "vertical",
        "item_spacing": 16,
        "elements": [
          {
            "type": "text",
            "content": "{card_header}",
            "font_family": "Salesforce Sans",
            "font_weight": "Bold", 
            "font_size": 20,
            "color": "#181818",
            "placeholder": "Order WW-2024-789456"
          },
          {
            "type": "data_rows",
            "layout": "label_value_pairs",
            "spacing": 12,
            "rows": [
              {"label": "Product:", "value": "{product_name}", "placeholder": "Item Name — e.g. Product Model, Size"},
              {"label": "Size:", "value": "{product_size}", "placeholder": "Men's 10.5"},
              {"label": "Color:", "value": "{product_color}", "placeholder": "Brown Leather"},
              {"label": "Price:", "value": "{product_price}", "placeholder": "$149.99"},
              {"label": "Order Date:", "value": "{order_date}", "placeholder": "March 15, 2024"},
              {"label": "Status:", "value": "{order_status}", "placeholder": "In Transit"}
            ],
            "label_styling": {
              "font_family": "Salesforce Sans",
              "font_weight": "Regular",
              "font_size": 14,
              "color": "#706E6B",
              "width": 120
            },
            "value_styling": {
              "font_family": "Salesforce Sans", 
              "font_weight": "Regular",
              "font_size": 14,
              "color": "#181818"
            }
          },
          {
            "type": "button",
            "variant": "brand",
            "content": "{cta_text}",
            "placeholder": "Continue to Tracking",
            "width": 180,
            "height": 40,
            "background": "#0176D3",
            "color": "#FFFFFF",
            "border_radius": 4,
            "font_family": "Salesforce Sans",
            "font_weight": "Bold",
            "font_size": 14
          }
        ]
      }
    },
    "slds_tokens": {
      "colors": {
        "success": "#45C65A",
        "brand": "#0176D3", 
        "text_primary": "#181818",
        "text_secondary": "#706E6B",
        "background_primary": "#FFFFFF",
        "background_page": "#FAFAFA",
        "border": "#D8DDE6"
      },
      "typography": {
        "font_family": "Salesforce Sans",
        "heading": {"size": 20, "weight": "Bold"},
        "body": {"size": 14, "weight": "Regular"},
        "button": {"size": 14, "weight": "Bold"},
        "banner": {"size": 16, "weight": "Bold"}
      },
      "spacing": {
        "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 20, "xxl": 24
      },
      "borders": {
        "radius_sm": 4, "radius_md": 8, "width": 1
      }
    },
    "accessibility": {
      "color_contrast": {
        "success_banner": "4.5:1",
        "primary_text": "7.2:1", 
        "secondary_text": "4.8:1",
        "button": "4.7:1"
      },
      "focus_states": true,
      "screen_reader": true,
      "semantic_structure": true
    },
    "responsive_breakpoints": {
      "mobile": {"width": 390, "container_padding": 16},
      "tablet": {"width": 768, "container_padding": 32},
      "desktop": {"width": 1200, "container_padding": 200}
    }
  }
}