# SF UX Orchestrator v2 — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real keys.

# Required: Figma personal access token
# Get it from: Figma → Profile → Settings → Personal access tokens
FIGMA_ACCESS_TOKEN=

# Optional: Anthropic API key
# Used by the ingestion agent for Claude-powered decision extraction and
# conflict detection. Without it, ingestion falls back to rule-based extraction.
# Get it from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
