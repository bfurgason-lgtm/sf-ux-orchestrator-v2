# Credentials & secrets — never commit these
.vscode/settings.json
.mcp.json
.claude/settings.json
.claude/settings.local.json
.claude/certs/

# Claude Code session data — tracked
!.claude/session_log_*.md
!.claude/memory/

# Session artifact docs
ACCURATE_WEB_TEMPLATE_REPLICATION_COMPLETE.md
AUTHENTIC_FIDELITY_IMPLEMENTATION_COMPLETE.md
FIGMA_DRIFT_FIX_COMPLETE.md
V1_AUTHENTIC_TEMPLATE_IMPLEMENTATION_COMPLETE.md
WOLVERINE_FIGMA_TEST_COMPLETE.md
WOLVERINE_TEST_ASSESSMENT.md

# Python
__pycache__/
*.pyc
*.pyo
venv/
.env
!.env.example

# Exports & generated files
exports/
/tmp/

# Projects — track config, manifest, decisions, and artifact_versions
# artifact_versions.json must be tracked (Agent 6 reads it for drift detection)
# Exclude only generated screen exports nested inside a project folder
projects/*/exports/

# macOS
.DS_Store
